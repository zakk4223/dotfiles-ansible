{
    "layer": "top",
    "position": "top",
    "height": 30,
    "reload_style_on_change": true,

    "modules-left": ["ext/workspaces", "mpris"],
    "modules-center": ["clock", "custom/weather", "cpu", "network"],
    "modules-right": ["battery", "pulseaudio#sink", "custom/notification", "tray" ],


    "ext/workspaces": {
			  "format": "{name}",
				"ignore-hidden": true,
				"on-click": "activate",
				"on-click-right": "deactivate",
				"sort-by-id": true
		},

		"mpris": {
			"format": "{status_icon}{artist} - {title}",
			"status-icons": {
				"paused": "´Őő "
			},
		},

    "cpu": {
      "interval": 5
    },

    "tray": {
        "icon-size": 21,
        "spacing": 10
      },


    "clock": {
        "format": "{:%a %d %b %H:%M}",
        "tooltip": true 
    },

    "network": {
        "interval": 5,
        "format": "{bandwidthUpBits} {bandwidthDownBits} {icon}",
        "format-alt": "{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-right",
        "format-icons": {
            "wifi": ["´Ü¬", "´Üź" ,"´çź"],
            "ethernet": ["´×ľ"],
            "disconnected": ["´ÜČ"]
        },
        "on-click": "termite -e nmtui",
    "tooltip": false 
    },

    "battery": {
        "format": "<span font='Font Awesome 5 Free 11'>{icon}</span>  {capacity}% - {time}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
        "format-time": "{H}h{M}m",
        "format-charging": "<span font='Font Awesome 5 Free'>´âž</span>  <span font='Font Awesome 5 Free 11'>{icon}</span>  {capacity}% - {time}",
        "format-full": "<span font='Font Awesome 5 Free'>´âž</span>  <span font='Font Awesome 5 Free 11'>{icon}</span>  Charged",
        "interval": 30,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "tooltip": false,
        "on-click": "2"
    },

    "pulseaudio#sink": {
        "format": "{icon} {volume}%",
        "format-muted": "´Üę",
        "format-icons": {
            "phone": ["´Çą ´ÇŽ", "´Çą ´Çž", "´Çą ´ÜĘ", "´Çą ´ÇĘ"],
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "scroll-step": 10,
        "on-click": "/home/zakk/bin/pulse_sink_toggle.py",
	"on-click-right": "pamixer -t",
	"on-click-middle": "pavucontrol",
        "tooltip": false
    },
    "custom/mediaplayer": {
   	"exec": "/home/zakk/.config/waybar/modules/mediaplayer.py",
	"format": "{}",
	"return-type": "json",
	"on-click": "playerctl play-pause",
	"on-scroll-up": "playerctl next",
	"on-scroll-down": "playerctl previous"
    },

    "custom/weather": {
        "format": "{}",
        "interval": 1800,
        "exec": "curl \"wttr.in?format=%c+%C+%t\"",
        "exec-if": "ping wttr.in -c1"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´Ćü",
            "deactivated": "´Çú"
        },
        "tooltip": false
    },


  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "´éó<span foreground='red'><sup>´Ĺä</sup></span>",
      "none": "´éó",
      "dnd-notification": "´çĚ<span foreground='red'><sup>´Ĺä</sup></span>",
      "dnd-none": "´çĚ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

    "tray": {
        "icon-size": 18
    }
}
